# shellcheck shell=dash disable=SC3001

set -e # exit on error

if [ "$#" -eq 0 ]; then
    echo "[ERROR] missing server ID number argument(s)"
    exit 1
fi

for serverid in "$@"; do
    if [ "${serverid}" = "${LDAP_SERVERID}" ]; then
        echo "[ERROR] Cannot remove the local running server itself"
        exit 1
    fi
done

# Retrieve the current slapd configuration once, then generate LDIF for all
# target serverIDs and apply them in a single ldapmodify call.  Using one
# transaction avoids the syncrepl reconnection storm (rc -100 quitting) that
# would be triggered by separate ldapmodify calls for each serverID.
tmpconfig=$(mktemp)
ldapsearch -Q -LLL -o ldif_wrap=no -b cn=config \
    '(|(objectClass=olcDatabaseConfig)(objectClass=olcGlobal))' olcSyncrepl olcServerID \
    > "${tmpconfig}"

{
    for serverid in "$@"; do
        awk -v "targetid=${serverid}" -f "${FILTERS_DIR}/update-syncrepl.awk" < "${tmpconfig}"
    done
} | tee "remove-server-combined.ldif" | ldapmodify -Q -c

rm -f "${tmpconfig}"

