# shellcheck shell=dash disable=SC3001

set -e # exit on error

if [ "$#" -eq 0 ]; then
    echo "[ERROR] missing server ID number argument(s)"
    exit 1
fi

for serverid in "$@"; do
    if [ "${serverid}" = "${LDAP_SERVERID}" ]; then
        echo "[ERROR] Cannot remove the local running server itself"
        exit 1
    fi
done

# Update syncrepl configuration on local remote server:
ldapsearch -Q -LLL -o ldif_wrap=no -b cn=config \
    '(|(objectClass=olcDatabaseConfig)(objectClass=olcGlobal))' olcSyncrepl olcServerID | \
    awk -v "targetids=$*" -f "${FILTERS_DIR}/update-syncrepl.awk" | \
    tee "remove-server-combined.ldif" | \
    ldapmodify -Q -c

